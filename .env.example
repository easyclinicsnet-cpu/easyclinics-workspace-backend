# ========================================
# APPLICATION CONFIGURATION
# ========================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
# Timezone — Central Africa Time (UTC+2). Used for local Date display,
# audit log timestamps, and date-fns helpers. DB always stores UTC.
TZ=Africa/Harare

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=a9fa7d31-7597-45c0-a15c-1ec2eea6ca0b
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_SSL=false

# ========================================
# JWT AUTHENTICATION
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=7d

# ========================================
# ENCRYPTION & SECURITY
# ========================================
# Used for encrypting sensitive patient data
ENCRYPTION_KEY=your-32-character-encryption-key-here-change-in-production
# Salt used in scrypt key derivation (ENCRYPTION_KEY + ENCRYPTION_SALT → 256-bit AES key)
# WARNING: changing this value re-keys ALL encrypted data — all existing ciphertext becomes
# unreadable. Generate once with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SALT=your-encryption-salt-here-change-in-production
ENCRYPTION_ALGORITHM=aes-256-cbc
BCRYPT_SALT_ROUNDS=10

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# ========================================
# RATE LIMITING
# ========================================
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# ========================================
# FILE UPLOAD
# ========================================
MAX_FILE_SIZE=10485760
UPLOAD_DESTINATION=./uploads

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# ========================================
# AUDIT & COMPLIANCE
# ========================================
AUDIT_RETENTION_DAYS=2555
ENABLE_AUDIT_LOGGING=true

# ========================================
# AI SERVICES (Optional)
# ========================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AZURE_AI_API_KEY=
DEFAULT_AI_PROVIDER=openai

# ========================================
# PORTAL BACKEND (AI Usage Billing)
# ========================================
PORTAL_API_BASE_URL=http://localhost:3005/api/v1
PORTAL_INTERNAL_API_KEY=your-internal-api-key-shared-with-portal
PORTAL_API_TIMEOUT=10000

# ========================================
# EXTERNAL SERVICES
# ========================================
# Email service
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@easyclinics.com

# SMS service
SMS_API_KEY=
SMS_API_SECRET=

# Payment Gateway
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_SECRET=

# ========================================
# FIREBASE (Push Notifications)
# ========================================
# Option 1: Path to Firebase service account JSON file (recommended)
FIREBASE_SERVICE_ACCOUNT_PATH=
# Option 2: Firebase project ID for Application Default Credentials (GCP / Cloud Run)
FIREBASE_PROJECT_ID=
